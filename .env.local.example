# ─── Local development (npm run dev) ───────────────────────────────────────
# Copy this file to .env.local and choose ONE database strategy below.

# ── Option A — Neon (recommended: your real cloud data) ─────────────────────
# Get the connection string from https://console.neon.tech → your project → Connect
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_SSL=true

# ── Option B — Docker Postgres on this machine ──────────────────────────────
# IMPORTANT (Windows): use port 5433, NOT 5432 — Windows often has another PostgreSQL on 5432.
# Start DB: docker compose up -d postgres redis
# Then run:  npm run db:sync-env && npm run db:seed-all && npm run db:check
POSTGRES_USER=hotel
POSTGRES_PASSWORD=hotel_secret_change_me
POSTGRES_DB=hotel_assistant
POSTGRES_PORT=5433
DATABASE_URL=postgresql://hotel:hotel_secret_change_me@localhost:5433/hotel_assistant
DATABASE_SSL=false

# ─── Shared app settings ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$replace_with_output_of_node_scripts_hash_password_js

# groq | ollama
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# If using Groq instead of Ollama:
# GROQ_API_KEY=gsk_your_key_here
