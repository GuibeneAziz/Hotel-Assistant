{
  "name": "tunisia-hotel-assistant",
  "version": "1.0.0",
  "description": "Tourist Assistant for Tunisia Hotels",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/check-database.mjs && next dev -p 3001",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/dev-clean.ps1",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "docker:up": "docker compose up --build -d",
    "docker:up:local": "docker compose -f docker-compose.yml -f docker-compose.local.yml up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:seed": "docker compose exec -e DATABASE_URL=postgresql://hotel:hotel_secret_change_me@postgres:5432/hotel_assistant -T app node scripts/seed-attractions.js",
    "docker:seed-settings": "docker compose exec -e DATABASE_URL=postgresql://hotel:hotel_secret_change_me@postgres:5432/hotel_assistant -T app node scripts/seed-hotel-settings.js",
    "docker:seed-all": "npm run docker:seed-settings && npm run docker:seed",
    "docker:verify": "node scripts/verify-docker.mjs",
    "fix:images": "node scripts/fix-attraction-images.js",
    "db:check": "node scripts/check-database.mjs",
    "env:init": "node scripts/init-env.mjs",
    "db:seed": "node scripts/seed-hotel-settings.js && node scripts/seed-attractions.js",
    "db:seed-all": "npm run db:seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.2",
    "dotenv": "^17.3.1",
    "framer-motion": "^10.16.0",
    "groq-sdk": "^0.37.0",
    "ioredis": "^5.9.3",
    "isomorphic-dompurify": "^3.0.0",
    "jsdom": "^28.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.292.0",
    "next": "^14.0.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^3.8.0",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
