# ─── Copier vers .env avant: docker compose up --build -d ────────────────────
#   cp .env.docker.example .env
#
# Identifiants admin par défaut (à changer en production):
#   utilisateur: admin
#   mot de passe: ChangeMeAdmin123!

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Base de données (service postgres sur le réseau internal) ─────────────
POSTGRES_USER=hotel
POSTGRES_PASSWORD=hotel_secret_change_me
POSTGRES_DB=hotel_assistant
DATABASE_SSL=false

# ─── Redis (service redis sur le réseau internal) ────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Traefik (réseau externe déjà présent sur le VPS) ──────────────────────
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_FRONT_HOST=chatbot.survey-flow.com
TRAEFIK_API_HOST=apichatbot.survey-flow.com
NEXT_PUBLIC_APP_URL=https://chatbot.survey-flow.com
NEXT_PUBLIC_API_URL=https://apichatbot.survey-flow.com

# ─── Admin JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=hotel-assistant-docker-jwt-secret-min-32-chars-2026
ADMIN_USERNAME=admin
# Mot de passe: ChangeMeAdmin123!
# Important Docker Compose: échapper chaque $ par $$ dans le hash bcrypt
ADMIN_PASSWORD_HASH=$$2a$$12$$ILmYAVsb1lBLBaO3jCYXvunU2XEJuzbUXV5ADpOIsYDcDM0lycn.W

# ─── IA ──────────────────────────────────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=8192

# Si AI_PROVIDER=groq à la place:
# GROQ_API_KEY=gsk_your_key_here

# ─── Optionnel ───────────────────────────────────────────────────────────────
ENABLE_RATE_LIMITING=true

# Local dev only — copier docker-compose.local.yml → docker-compose.override.yml
# POSTGRES_PORT=5433
# REDIS_PORT=6379
# APP_PORT=3001
