# =============================================================================
# Hotel Assistant — single environment file
# =============================================================================
#
# Setup (first time):
#   cp .env.example .env
#   Edit .env with your secrets — never commit .env to git
#
# If you still have .env.local from an older setup, merge its values into .env
# and delete .env.local so nothing overrides this file.
#
# ── How to run ───────────────────────────────────────────────────────────────
#
# Local dev + Neon (cloud DB):
#   Uncomment the Neon DATABASE_URL block below, comment out the Docker block.
#   npm run db:check && npm run dev
#
# Local dev + Docker Postgres:
#   docker compose up -d postgres redis
#   Use the Docker block below (port 5433 on Windows — not 5432).
#   npm run db:seed && npm run db:check && npm run dev
#
# VPS production (Docker Compose + Traefik):
#   Fill secrets below, set NODE_ENV=production and Traefik hosts.
#   docker compose up --build -d
#   (Compose overrides DATABASE_URL / REDIS_URL inside containers.)
#
# =============================================================================


# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001


# ─── Database ────────────────────────────────────────────────────────────────
# Use ONE of the following strategies.

# A) Neon — real cloud data (recommended for local dev)
# Get the string from https://console.neon.tech → Connect
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_SSL=true

# B) Local Docker Postgres (start: docker compose up -d postgres redis)
POSTGRES_USER=hotel
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=hotel_assistant
POSTGRES_PORT=5433
POSTGRES_HOST=postgres
DATABASE_URL=postgresql://hotel:replace-with-a-long-random-password@postgres:5432/hotel_assistant
DATABASE_SSL=false

# C) VPS — credentials for the postgres service (compose wires the app URL)
# POSTGRES_USER=hotel
# POSTGRES_PASSWORD=hotel_secret_change_me
# POSTGRES_DB=hotel_assistant
# DATABASE_SSL=false


# ─── Redis ───────────────────────────────────────────────────────────────────
# Local dev:           redis://localhost:6379
# Docker (internal):   redis://redis:6379  (set automatically in docker-compose.yml)
REDIS_URL=redis://redis:6379


# ─── Admin authentication ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
ADMIN_USERNAME=admin
# Generate hash: node scripts/hash-password.js YourPassword
ADMIN_PASSWORD_HASH='$2a$12$replace_with_output_of_node_scripts_hash_password_js'
# Keep bcrypt hashes single-quoted so Docker Compose preserves every $ character.


# ─── AI ──────────────────────────────────────────────────────────────────────
# Ollama runs inside this Docker Compose stack.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=160
OLLAMA_REQUEST_TIMEOUT_MS=45000
# ─── Public URLs (production / Docker build) ─────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://chatbot.survey-flow.com
# NEXT_PUBLIC_API_URL=https://apichatbot.survey-flow.com


# ─── Traefik (VPS — external network already on the host) ────────────────────
TRAEFIK_NETWORK=screenflow-public
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_FRONT_HOST=chatbot.survey-flow.com
TRAEFIK_API_HOST=apichatbot.survey-flow.com


# ─── Optional ────────────────────────────────────────────────────────────────
ENABLE_RATE_LIMITING=true
# ALLOWED_ORIGINS=https://your-domain.com
# OPENTRIPMAP_API_KEY=
# FOURSQUARE_API_KEY=

# Local port publishing (docker-compose.local.yml / override):
# APP_PORT=3001
# REDIS_PORT=6379
